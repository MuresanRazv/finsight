# ==============================================================================
# FinSight Production Environment Variables Template (.env.prod)
# Copy this file to `.env.prod` on your production server:
# cp .env.prod.example .env.prod
# Fill in the actual values before running `docker compose -f docker-compose.prod.yml up -d`
# ==============================================================================

# ------------------------------------------------------------------------------
# Traefik & Domain Settings
# ------------------------------------------------------------------------------
# The domain name where the application will be hosted (e.g., finsight.yourdomain.com)
# Ensure your domain's A/AAAA DNS records point to your Hetzner VPS IP.
DOMAIN_NAME=finsight.yourdomain.com

# Email address for Let's Encrypt certificate renewal alerts and notifications
ACME_EMAIL=admin@yourdomain.com

# ------------------------------------------------------------------------------
# Database Settings (TimescaleDB)
# ------------------------------------------------------------------------------
# Database name, username, and a strong production password
DB_NAME=sentiment_hub
DB_USER=finsight_admin
DB_PASSWORD=YOUR_STRONG_PRODUCTION_DB_PASSWORD_HERE

# ------------------------------------------------------------------------------
# Message Broker (RabbitMQ)
# ------------------------------------------------------------------------------
# Username and a strong production password for RabbitMQ
RABBITMQ_USER=rabbitmq_admin
RABBITMQ_PASSWORD=YOUR_STRONG_PRODUCTION_RABBITMQ_PASSWORD_HERE
# Internal host configurations (keep these as is)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ------------------------------------------------------------------------------
# Caching & Vector Database Hosts (Internal - Keep as is)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ------------------------------------------------------------------------------
# Core API Settings
# ------------------------------------------------------------------------------
# A strong secret key used for signing JWT tokens (at least 64 hex characters)
# Generate one using: openssl rand -hex 32
JWT_SECRET=YOUR_64_HEX_CHARACTERS_JWT_SECRET_HERE

# ------------------------------------------------------------------------------
# External API Keys & LLM Configurations
# ------------------------------------------------------------------------------
# Finnhub API Key (used by web-client for stock profiles and quotes)
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE

# Gemini API Configurations (used by nlp-engine for processing news)
USE_GEMINI=true
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3.1-flash-lite

# News API Key (used by nlp-engine for raw news ingestion)
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# Optional local LLM setup (if running Ollama or similar locally)
LLM_HOST=http://192.168.0.65:11434
LLM_MODEL=qwen3:8b

# ------------------------------------------------------------------------------
# NLP Engine Processing Parameters
# ------------------------------------------------------------------------------
QUEUE_RAW_NEWS=raw_financial_news
QUEUE_ANALYZED_SENTIMENT=analyzed_sentiment

RAG_MAX_RESULTS=5
RAG_MAX_PARAGRAPHS_PER_DOC=2
RAG_MAX_CHARS_PER_DOC=2000
